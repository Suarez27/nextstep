# Backend config
PORT=4000
JWT_SECRET=nextstep-dev-secret

# Database mode: mysql | sqlite
DB_CLIENT=mysql

# MySQL local (WAMP/XAMPP/phpMyAdmin)
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=nextstep
MYSQL_BIN=C:\\wamp64\\bin\\mysql\\mysql8.4.7\\bin\\mysql.exe

# SQLite fallback path (used only when DB_CLIENT=sqlite)
NEXTSTEP_DB_PATH=./data/nextstep.sqlite
